---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: csi-manila-node-sa
  namespace: kube-system

---
kind: ClusterRole
apiVersion: rbac.authorization.k8s.io/v1
metadata:
  name: csi-manila-nodeplugin-role
rules:
  - apiGroups: [""]
    resources: ["events"]
    verbs: ["get", "list", "watch", "create", "update", "patch"]

---
kind: ClusterRoleBinding
apiVersion: rbac.authorization.k8s.io/v1
metadata:
  name: csi-manila-nodeplugin-binding
subjects:
  - kind: ServiceAccount
    name: csi-manila-node-sa
    namespace: kube-system
roleRef:
  kind: ClusterRole
  name: csi-manila-nodeplugin-role
  apiGroup: rbac.authorization.k8s.io
